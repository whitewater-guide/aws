{
  "$schema": "https://json.schemastore.org/tsconfig",
  "compilerOptions": {
    "target": "esnext",
    "module": "esnext",
    "moduleResolution": "bundler",
    "lib": ["esnext"],
    "types": ["node"],
    "allowSyntheticDefaultImports": true,
    "esModuleInterop": true,
    "declaration": true,
    "strict": true,
    "strictFunctionTypes": false,
    "skipLibCheck": true,
    "inlineSourceMap": true,
    "inlineSources": true,
    "outDir": "dist"
  },
  "exclude": ["cdk.out", "node_modules", "dist"]
}
