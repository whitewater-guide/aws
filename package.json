{
  "name": "@whitewater-guide/aws",
  "version": "0.0.0",
  "bin": {
    "aws": "bin/aws.js"
  },
  "private": true,
  "type": "module",
  "scripts": {
    "cdk": "cdk",
    "prepare": "husky",
    "check": "biome check --write",
    "check:ci": "biome check",
    "typecheck:ci": "tsc --noEmit"
  },
  "dependencies": {
    "aws-cdk-lib": "^2.51.1",
    "aws-lambda": "^1.0.7",
    "aws-sdk": "^2.1258.0",
    "chalk": "^5.6.2",
    "commander": "^14.0.3",
    "constructs": "^10.1.164",
    "lodash": "^4.17.21",
    "p-wait-for": "6.0.0",
    "pg": "^8.8.0",
    "source-map-support": "^0.5.21",
    "uuid": "^13.0.0"
  },
  "devDependencies": {
    "@aws-cdk/assert": "2.68.0",
    "@biomejs/biome": "^2.4.11",
    "@commitlint/config-conventional": "^20.5.0",
    "@types/aws-lambda": "^8.10.108",
    "@types/aws-sdk": "^2.7.0",
    "@types/lodash": "^4.14.189",
    "@types/node": "25.6.0",
    "@types/pg": "^8.6.5",
    "@typescript-eslint/eslint-plugin": "^8.58.0",
    "@typescript-eslint/parser": "^8.58.0",
    "aws-cdk": "2.1118.0",
    "commitlint": "^20.5.0",
    "esbuild": "0.28.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2",
    "utility-types": "^3.10.0"
  },
  "commitlint": {
    "extends": [
      "@commitlint/config-conventional"
    ]
  },
  "lint-staged": {
    "*.{ts,tsx,mts,mjs,json}": [
      "biome check --no-errors-on-unmatched --write"
    ]
  },
  "packageManager": "pnpm@10.32.1"
}
